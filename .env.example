# ── Banco (Aiven MySQL 8) ──────────────────────────────────────────────────────
# connection_limit: máximo de conexões simultâneas por instância do app
#   Cálculo: max_connections_aiven / instâncias_render - 2 (reserva para Aiven Console)
#   Aiven free: max_connections=25 → 1 instância: 10  |  2 instâncias: 5
#   Aiven startup: max_connections=75 → 1 instância: 25 |  3 instâncias: 10
# pool_timeout: segundos aguardando conexão livre antes de erro (padrão: 10)
# connect_timeout: segundos aguardando conexão TCP com o servidor (padrão: 5)
DATABASE_URL="mysql://avnadmin:YOUR_PASSWORD@mysql-3607bd0a-nandomarzola1-2d86.a.aivencloud.com:25641/defaultdb?ssl-mode=REQUIRED&connection_limit=10&pool_timeout=20&connect_timeout=10"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=3333
NODE_ENV=production

# ── Autenticação ──────────────────────────────────────────────────────────────
# JWT_SECRET deve ser uma string aleatória de ≥ 32 chars. Nunca commitar o valor real.
JWT_SECRET="SUBSTITUA_POR_STRING_ALEATORIA_32CHARS"

# ── Uploads ───────────────────────────────────────────────────────────────────
UPLOAD_DIR="./uploads"

# ── Integrações marketplace (opcionais por loja) ──────────────────────────────
ML_CLIENT_ID=""
ML_CLIENT_SECRET=""
ML_REDIRECT_URI=""

SHOPEE_PARTNER_ID=""
SHOPEE_PARTNER_KEY=""
SHOPEE_REDIRECT_URL=""
SHOPEE_FRONTEND_URL="https://profittrack.ecomzero.com.br"

TIKTOK_APP_KEY=""
TIKTOK_APP_SECRET=""

# ── Worker de recálculo (BullMQ — opcional) ───────────────────────────────────
# ENABLE_WORKER=true  # descomente para ativar worker em background
# REDIS_URL="redis://localhost:6379"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  plan       String    @default("free")
  role       String    @default("seller")
  cnpj       String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  stores         Store[]
  suppliers      Supplier[]
  bills          Bill[]
  purchaseOrders PurchaseOrder[]
  newsReads      NewsRead[]
  goals          Goal[]
}

model Store {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  marketplace     String
  taxType         String    @default("mei")
  taxRate         Float     @default(0)
  fixedMonthlyTax Float     @default(0) // DAS mensal (MEI) — valor fixo, não percentual
  createdAt       DateTime  @default(now())
  mlAccessToken    String?
  mlRefreshToken   String?
  mlSellerId       String?
  mlTokenExpiresAt DateTime?

  ttAccessToken    String?   // TikTok Shop access token
  ttRefreshToken   String?
  ttShopId         String?   // TikTok Shop ID
  ttTokenExpiresAt DateTime?

  spAccessToken    String?   // Shopee access token (OAuth v2)
  spRefreshToken   String?
  spShopId         String?   // Shopee shop_id
  spShopName       String?
  spTokenExpiresAt DateTime?

  products         Product[]
  orders           Order[]
  imports          Import[]
  bills            Bill[]
  shopeeSummaries  ShopeePeriodSummary[]
  monthlyClosings  MonthlyClosing[]
  storeRates       StoreRate[]
}

model Product {
  id         String      @id @default(uuid())
  storeId    String
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  externalId    String?   // ML: item_id do anúncio
  mlListingType String?   // gold_pro | gold_special | free
  mlFeeRate     Float?    // taxa de comissão real (%) cobrada pelo ML
  mlStatus      String?   // active | paused | closed | under_review
  name       String
  sku        String?
  barcode    String?
  costPrice  Float
  listPrice  Float       @default(0)
  packaging  Float       @default(0)
  supplies   Float       @default(0)
  stock      Int         @default(0)
  minStock   Int         @default(5)
  variations Json?       // Shopee: [{ modelId, sku, name, price, stock }] — variações do anúncio (matching/exibição)
  parentId   String?
  parent     Product?    @relation("Variants", fields: [parentId], references: [id], onDelete: SetNull)
  variants   Product[]   @relation("Variants")
  createdAt  DateTime    @default(now())
  orders             Order[]
  purchaseOrderItems PurchaseOrderItem[]
}

// ── Controle de importações ──────────────────────────────────────────────────
model Import {
  id                   String   @id @default(uuid())
  storeId              String
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  filename             String
  periodMonth          String   // "YYYY-MM"
  importedAt           DateTime @default(now())
  totalRows            Int      @default(0)
  validCount           Int      @default(0)
  pendingCount         Int      @default(0)
  cancelledCount       Int      @default(0)
  returnedFullCount    Int      @default(0)
  returnedPartialCount Int      @default(0)
  gmv                  Float    @default(0)
  shopeeDeductions     Float    @default(0)
  netRevenue           Float    @default(0)
  grossProfit          Float    @default(0)
  skippedCount         Int      @default(0)
  newProductCount      Int      @default(0)
  status               String   @default("processing") // processing|done|error
  errorMessage         String?
  jobId                String?
  orders               Order[]
}

// ── Pedidos (1 linha = 1 linha do arquivo Shopee) ────────────────────────────
model Order {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  importId  String?
  import    Import?  @relation(fields: [importId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  // ── Identidade do pedido ──────────────────────────────────────────────────
  orderId       String   // "ID do pedido" Shopee
  orderStatus   String   @default("")
  orderCategory String   @default("valid")  // valid|pending|cancelled_unpaid|cancelled_other|returned_full|returned_partial
  cancelReason  String?  @db.Text
  returnStatus  String?

  // ── Identidade do produto ─────────────────────────────────────────────────
  skuPrincipal  String?
  skuVariacao   String?
  productName   String?  @db.Text
  variationName String?
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  // ── Preços (do arquivo) ───────────────────────────────────────────────────
  originalPrice Float    @default(0)
  agreedPrice   Float    @default(0)
  quantity      Int      @default(1)

  // ── Custos Shopee (do arquivo — para referência, NÃO usado no cálculo) ───
  platformCommission Float  @default(0)
  platformServiceFee Float  @default(0)
  sellerCoupon     Float  @default(0)
  sellerDiscount   Float  @default(0)
  lmmDiscount      Float  @default(0)

  // ── Totais do arquivo ─────────────────────────────────────────────────────
  globalTotal Float  @default(0)
  orderTotal  Float  @default(0)

  // ── Logística ─────────────────────────────────────────────────────────────
  listingType      String?  // ML: gold_pro=Premium | gold_special=Clássico | free=Grátis
  mlShippingCost   Float    @default(0)  // Frete pago pelo VENDEDOR (Mercado Envios)
  mlInstallmentFee Float    @default(0)  // Taxa de parcelamento cobrada pelo ML (total_paid - paid_amount)
  trackingNumber   String?
  shippingOption   String?
  orderCreatedAt   DateTime?
  orderPaidAt      DateTime?
  orderDeliveredAt DateTime?

  // ── Campos calculados (salvos no banco, fonte única: calcOrderProfit) ─────
  calcGmv         Float   @default(0)
  calcShopeeFee   Float   @default(0)
  calcNetRevenue  Float   @default(0)
  calcTax         Float   @default(0)
  calcProductCost Float   @default(0)
  calcPackaging   Float   @default(0)
  calcGrossProfit Float   @default(0)
  calcMargin      Float   @default(0)
  hasCost         Boolean @default(false)

  // ── Compat com dashboard/cashflow existentes ──────────────────────────────
  status    String   @default("paid")  // paid|cancelled|returned
  soldAt    DateTime?
  salePrice Float    @default(0)
  profit    Float?
  margin    Float?
  snapshotTaxRate Float @default(0)

  @@unique([storeId, orderId])
}

// ───────────────────────────────────────────
// FORNECEDORES
// ───────────────────────────────────────────
model Supplier {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  contact   String?
  phone     String?
  email     String?
  cnpj      String?
  notes     String?
  leadDays  Int      @default(7)
  createdAt DateTime @default(now())
  bills          Bill[]
  purchaseOrders PurchaseOrder[]
}

// ───────────────────────────────────────────
// CONTAS A PAGAR
// ───────────────────────────────────────────
model Bill {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeId     String?
  store       Store?    @relation(fields: [storeId], references: [id])
  supplierId  String?
  supplier    Supplier? @relation(fields: [supplierId], references: [id])
  description String
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  status      String    @default("pending")
  category    String    @default("outros")
  recurring   Boolean   @default(false)
  recurrence  String?
  notes       String?
  createdAt   DateTime  @default(now())
}

// ───────────────────────────────────────────
// PEDIDOS DE COMPRA
// ───────────────────────────────────────────
model PurchaseOrder {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  supplierId String?
  supplier   Supplier?           @relation(fields: [supplierId], references: [id])
  status     String              @default("draft")
  orderedAt  DateTime?
  expectedAt DateTime?
  receivedAt DateTime?
  notes      String?
  total      Float               @default(0)
  createdAt  DateTime            @default(now())
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  quantity        Int
  unitCost        Float
}

// ───────────────────────────────────────────
// NOVIDADES DO SISTEMA
// ───────────────────────────────────────────
model SystemNews {
  id          String     @id @default(uuid())
  title       String
  content     String     @db.Text
  type        String     @default("feature")
  createdBy   String
  publishedAt DateTime   @default(now())
  reads       NewsRead[]
}

model NewsRead {
  id     String     @id @default(uuid())
  userId String
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  newsId String
  news   SystemNews @relation(fields: [newsId], references: [id], onDelete: Cascade)
  readAt DateTime   @default(now())
  @@unique([userId, newsId])
}

// ───────────────────────────────────────────
// METAS MENSAIS
// ───────────────────────────────────────────
model Goal {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  month     String
  revenue   Float    @default(0)
  profit    Float    @default(0)
  orders    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, month])
}

// ───────────────────────────────────────────
// RESUMO FINANCEIRO SHOPEE POR PERÍODO
// ───────────────────────────────────────────
// ───────────────────────────────────────────
// FECHAMENTOS MENSAIS
// ───────────────────────────────────────────
// ── Logs de acesso ────────────────────────────────────────────────────────────
model AccessLog {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  action    String   // login | logout | api_call | login_failed
  ip        String?
  userAgent String?  @db.Text
  endpoint  String?
  status    Int?     // HTTP status
  createdAt DateTime @default(now())
}

model MonthlyClosing {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  periodMonth     String   // "2026-05"
  closedAt        DateTime @default(now())
  closedBy        String   @default("")
  status          String   @default("closed") // "open" | "closed"

  totalOrders     Int      @default(0)
  confirmedOrders Int      @default(0)
  pendingOrders   Int      @default(0)
  cancelledOrders Int      @default(0)
  returnedOrders  Int      @default(0)
  unitCount       Int      @default(0)

  gmvTotal         Float   @default(0)
  gmvConfirmed     Float   @default(0)
  gmvPending       Float   @default(0)
  shopeeDeductions Float   @default(0)
  sellerDiscounts  Float   @default(0)
  netRevenue       Float   @default(0)
  taxAmount        Float   @default(0)
  fixedTaxAmount   Float   @default(0) // DAS mensal (MEI)
  productCost      Float   @default(0)
  packagingCost    Float   @default(0)
  grossProfit      Float   @default(0)
  avgMargin        Float   @default(0)

  cancelledGmv  Float @default(0)
  returnedValue Float @default(0)

  productsSnapshot Json

  @@unique([storeId, periodMonth])
}

model StoreRate {
  id                Int      @id @default(autoincrement())
  storeId           String
  store             Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  month             Int
  year              Int
  totalOrders       Int      @default(0)
  avgCommissionRate Decimal  @db.Decimal(8, 4)
  avgServiceFeeRate Decimal  @db.Decimal(8, 4)
  avgShippingFee    Decimal  @db.Decimal(10, 2)
  effectiveRate     Decimal  @db.Decimal(8, 4)
  totalGmv          Decimal  @db.Decimal(12, 2)
  totalNetRevenue   Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([storeId, month, year])
}

model ShopeePeriodSummary {
  id                   String   @id @default(uuid())
  storeId              String
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  month                String
  gmv                  Float    @default(0)
  shopeeDeductions     Float    @default(0)
  netRevenue           Float    @default(0)
  tax                  Float    @default(0)
  grossProfit          Float    @default(0)
  margin               Float    @default(0)
  validCount           Int      @default(0)
  unitCount            Int      @default(0)
  cancelledCount       Int      @default(0)
  cancelledGmv         Float    @default(0)
  unpaidCount          Int      @default(0)
  unpaidGmv            Float    @default(0)
  returnedFullCount    Int      @default(0)
  returnedFullValue    Float    @default(0)
  returnedPartialCount Int      @default(0)
  returnedPartialValue Float    @default(0)
  cancelReasonBreakdown String? @db.Text
  updatedAt            DateTime @updatedAt
  @@unique([storeId, month])
}
